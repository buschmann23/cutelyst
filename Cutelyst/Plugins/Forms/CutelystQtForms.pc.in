prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/include/cutelyst@PROJECT_VERSION_MAJOR@-qt@QT_VERSION_MAJOR@

Name: Cutelyst Qt@QT_VERSION_MAJOR@ Forms Plugin
Description: Cutelyst Forms plugin
Version: @PROJECT_VERSION@
Requires: @PLUGIN_FORMS_PKGCONFIG_REQUIRES@
Libs: -L${libdir} -lCutelyst@PROJECT_VERSION_MAJOR@Qt5CSRFProtection
Cflags: -I${includedir}/Cutelyst -I${includedir}
